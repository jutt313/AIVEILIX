# Copy to deploy/gcp/config.env and adjust only if needed.

PROJECT_ID=aiveilix-499209
REGION=us-central1
ZONE=us-central1-a

APP_NAME=aiveilix
LABELS=app=aiveilix,env=prod-test,owner=codex

# Cost guards: keep these conservative for the first production-grade test.
CLOUD_RUN_MIN_INSTANCES=0
CLOUD_RUN_MAX_INSTANCES=3
CLOUD_RUN_CPU=1
CLOUD_RUN_MEMORY=2Gi
CLOUD_RUN_CONCURRENCY=10
CLOUD_RUN_TIMEOUT=900

# Self-hosted Qdrant + Valkey VM.
VM_NAME=aiveilix-vector-cache
VM_MACHINE_TYPE=e2-medium
VM_BOOT_DISK_SIZE=30GB
VM_DATA_DISK_SIZE=100GB
VM_DATA_DISK_TYPE=pd-balanced

# Cloud SQL, intentionally non-HA and fixed small storage for cost control.
SQL_INSTANCE=aiveilix-postgres
SQL_DATABASE=aiveilix
SQL_USER=aiveilix
SQL_CPU=1
SQL_MEMORY=3840MiB
SQL_STORAGE_SIZE=20
SQL_VERSION=POSTGRES_16

# Artifact Registry and services.
ARTIFACT_REPO=aiveilix
BACKEND_SERVICE=aiveilix-api
VPC_CONNECTOR=aiveilix-connector
VPC_CONNECTOR_RANGE=10.8.0.0/28

# Firebase default hosting URL. Custom domains can come later.
FRONTEND_URL=https://aiveilix-499209.web.app
