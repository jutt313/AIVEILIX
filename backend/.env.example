# App
APP_ENV=development
SECRET_KEY=your-secret-key-here
PORT=4565

# PostgreSQL
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/aiveilix

# Qdrant — optional embedded mode (same path as database/qdrant bootstrap); when set, host/port are ignored
# QDRANT_PATH=/absolute/path/to/backend/database/qdrant/data/local
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Valkey (Redis-compatible)
VALKEY_URL=redis://127.0.0.1:6380

# Cloudflare R2
R2_ACCOUNT_ID=your-account-id
R2_ACCESS_KEY_ID=your-access-key
R2_SECRET_ACCESS_KEY=your-secret-key
R2_BUCKET_NAME=aiveilix
R2_PUBLIC_URL=https://your-r2-url.r2.dev

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Gemini (for file visual processing + optional LLM)
GEMINI_API_KEY=your-gemini-api-key

# LLM (backend pick)
# Supported: auto, claude, gemini, openai, deepseek, kimi
LLM_PROVIDER=auto
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
MOONSHOT_API_KEY=your-kimi-api-key
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# Stripe
STRIPE_SECRET_KEY=your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=your-stripe-webhook-secret
# Price IDs from Stripe Dashboard → Products (one recurring price per plan)
STRIPE_PRICE_INDIVIDUAL=price_xxx_individual_15
STRIPE_PRICE_TEAM=price_xxx_team_49
STRIPE_PRICE_MCP=price_xxx_mcp_12

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Email (SMTP — set when Google Workspace approved)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=info@aiveilix.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=info@aiveilix.com
SMTP_FROM_NAME=AIveilix
